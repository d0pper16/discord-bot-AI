# =============================================================
#  YANTO BOT - .env (WAJIB diisi sebelum deploy)
# =============================================================

# --- DISCORD ---
DISCORD_TOKEN=
YANTO_CHANNEL_ID=

# --- GEMINI API (min 1, max 5) ---
# API ke-1 WAJIB. API ke-2..5 opsional sebagai fallback.
# Kalau key ke-N kena rate-limit, otomatis switch ke key berikutnya.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- DISCORD RICH PRESENCE (opsional, untuk mode 'richpresence') ---
# Application ID dari Discord Developer Portal -> Your App -> General Information
# WAJIB diisi kalau pakai presence mode = "richpresence" (image asset)
# Bisa kosongin kalau cuma pakai mode "custom" atau "streaming"
DISCORD_APP_ID=

# --- DASHBOARD ---
DASHBOARD_PORT=3001

# Akun DEVELOPER (full administrator)
DEV_USER=dev
DEV_PASS=devtbiapril2026

# Akun ADMIN (read-only + edit Persona Overlay)
ADMIN_USER=admin
ADMIN_PASS=admintbi2026

# =============================================================
#  CATATAN DEPLOY (VPS):
#  1. Copy file ini -> .env
#  2. Isi DISCORD_TOKEN, YANTO_CHANNEL_ID, GEMINI_API_KEY_1
#  3. (Opsional) Isi GEMINI_API_KEY_2..5 sebagai fallback
#  4. Ganti DEV_PASS dan ADMIN_PASS dengan password kuat
#  5. npm install
#  6. npm start
#
#  Setelah bot jalan, channel id + API keys juga bisa diubah
#  via tab "Connection" di dashboard (override .env, disimpan
#  di data/runtime.json).
# =============================================================
